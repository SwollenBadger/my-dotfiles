#!/bin/sh

function lid_on() {
    monitors=$(hyprctl monitors -j | jq length)
    hyprctl keyword monitor "eDP-1,preferred,auto,1"
    hyprctl dispatch dpms on
}

function lid_off() {
    monitors=$(hyprctl monitors -j | jq length)
    if (( "$monitors" > "1" )); then
        hyprctl keyword monitor "eDP-1, disable"
    else
        hyprlock
        hyprctl dispatch dpms off
    fi
}

case "$1" in
    "on")
        lid_on ;;
    "off")
        lid_off ;;
esac


